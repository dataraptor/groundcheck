# groundcheck — environment template. Copy to `.env` (gitignored) and fill in.
#
# You do NOT need any key for the demo or the no-key test suite: the default web
# demo and CLI run on a deterministic MockProvider. Only the real `check()` and the
# meta-eval (`python -m eval.run`) call a live model.

# --- provider selection ------------------------------------------------------- #
# mock | anthropic | openai. Leave unset to auto-detect by which key is present.
# Set to `mock` to force the no-key, deterministic path (the money demo prints 62%).
GROUNDCHECK_LLM=mock

# --- Option A: Anthropic (the spec-canonical path: Sonnet 4.6 + Opus 4.8) ------ #
# ANTHROPIC_API_KEY=

# --- Option B: Azure OpenAI (gpt-5.5) — the path used in this environment ------ #
# A single Azure deployment serves both the decompose and ground steps. Its list
# price is an ESTIMATE in config.py, so live cost figures are approximate.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# OPENAI_API_VERSION=2025-01-01-preview
# CHAT_LLM_MODEL=gpt-5.5        # or AZURE_OPENAI_DEPLOYMENT=<deployment-name>
